PORT=3000
JWT_SECRET=techstore-dev-secret
JWT_EXPIRES_IN=8h
DB_FILE=./data/techstore.db
MFA_CODE_TTL_MINUTES=5
MFA_MAX_ATTEMPTS=3
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
EXPOSE_MFA_CODE=true
MAILBOX_DIR=./tmp/mailbox

# Docker SMTP/email settings.
# Default recomendado para laboratorio: preview.
# Para QR/OTP con app autenticadora no necesitas SMTP.
EMAIL_DELIVERY_MODE=preview
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=techstore@example.com
